@prefix : <http://example.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:asserts rdfs:subPropertyOf rdf:reifies .
_:claim :said_by :bob .
_:claim :asserts <<( :moon :made_of :cheese )>> .
:report :mentions << :moon :made_of :cheese ~ _:claim >> .
